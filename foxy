def show_help():
    print(FOX_ASCII)
    print("\033[1;31m🦊 Foxy CLI Launcher v1.5\033[0m")
    print("\033[92mUsage:\033[0m foxy [app_name]")
    print("\n\033[92mExamples:\033[0m")
    print("  foxy chrome     -> Opens Google Chrome")
    print("  foxy code       -> Opens VS Code")
    print("  foxy files      -> Opens File Manager")

def open_app(app_name):
    # قائمة الاختصارات - تقدر تزود براحتك هنا
    apps = {
        "chrome": "google-chrome",
        "youtube": "google-chrome https://youtube.com",
        "code": "code",
        "terminal": "gnome-terminal",
        "files": "nautilus"
    }
    
    cmd = apps.get(app_name, app_name)
    try:
        subprocess.Popen(cmd.split(), stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print(f"🦊 \033[92mFoxy jumped!\033[0m Opening {app_name}...")
    except:
        print(f"❌ \033[31mError:\033[0m Could not find '{app_name}'.")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        show_help()
    else:
        open_app(sys.argv[1].lower())
